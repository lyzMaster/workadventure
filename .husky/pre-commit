#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$REPO_ROOT"

run_npm_script_if_present() {
  local directory="$1"
  local script_name="$2"

  if [ ! -f "$directory/package.json" ]; then
    return 0
  fi

  (
    cd "$directory"
    npm run --if-present "$script_name"
  )
}

run_npm_script_if_present play precommit
run_npm_script_if_present play i18n:check
run_npm_script_if_present tests precommit
run_npm_script_if_present libs/map-editor precommit
run_npm_script_if_present libs/shared-utils precommit
run_npm_script_if_present libs/store-utils precommit
