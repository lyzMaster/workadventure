{
    "private": true,
    "name": "workadventure-play",
    "version": "1.0.0",
    "type": "module",
    "license": "SEE LICENSE IN LICENSE.txt",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/thecodingmachine/workadventure.git"
    },
    "bugs": {
        "url": "https://github.com/thecodingmachine/workadventure/issues"
    },
    "homepage": "https://github.com/thecodingmachine/workadventure#readme",
    "scripts": {
        "dev": "npm run dev:standalone",
        "dev:standalone": "cross-env vite --config vite.standalone.config.ts --open /standalone.html",
        "build:standalone": "cross-env vite build --config vite.standalone.config.ts",
        "preview:standalone": "cross-env vite preview --config vite.standalone.config.ts",
        "test": "vitest --config vitest.standalone.config.ts",
        "test:e2e:standalone": "cross-env VITE_ENABLE_TEST_BRIDGE=true playwright test --config standalone.playwright.config.ts",
        "test:e2e:standalone:headed": "cross-env VITE_ENABLE_TEST_BRIDGE=true playwright test --config standalone.playwright.config.ts --headed",
        "typecheck:standalone": "cross-env tsc --noEmit --project tsconfig.standalone.json"
    },
    "lint-staged": {
        "*.svelte": [
            "cross-env NODE_PATH=./node_modules svelte-check --compiler-warnings \"a11y-media-has-caption:ignore,a11y-no-onchange:ignore,a11y-autofocus:ignore,a11y-media-has-caption:ignore,a11y-click-events-have-key-events:ignore,security-anchor-rel-noreferrer:ignore\""
        ],
        "*.{ts,svelte}": [
            "eslint --fix",
            "prettier --write"
        ]
    },
    "devDependencies": {
        "@playwright/test": "^1.60.0",
        "@sveltejs/vite-plugin-svelte": "^7.1.2",
        "@tailwindcss/vite": "^4.3.0",
        "@tsconfig/svelte": "^5.0.8",
        "@types/debug": "^4.1.13",
        "@types/node": "^25.9.1",
        "@types/uuid": "^10.0.0",
        "fake-indexeddb": "^6.2.5",
        "jsdom": "^29.1.1",
        "prettier": "^3.8.3",
        "prettier-plugin-svelte": "^4.0.1",
        "svelte-check": "^4.4.8",
        "tailwindcss": "^4.3.0",
        "tslib": "^2.8.1",
        "typescript": "^5.9.3",
        "vite": "^8.1.4",
        "vite-tsconfig-paths": "^6.1.1",
        "vitest": "^4.1.7"
    },
    "dependencies": {
        "@sentry/svelte": "^10.54.0",
        "@workadventure/game-model": "1.0.0",
        "@workadventure/map-editor": "1.0.0",
        "@workadventure/math-utils": "1.0.0",
        "@workadventure/shared-utils": "1.0.0",
        "@workadventure/tailwind": "1.0.0",
        "@workadventure/world-command": "1.0.0",
        "@workadventure/tiled-map-type-guard": "^2.1.2",
        "cancelable-promise": "^4.3.1",
        "catch-unknown": "^2.0.0",
        "cross-env": "^10.1.0",
        "debug": "^4.4.3",
        "deepmerge-ts": "^7.1.5",
        "easystarjs": "^0.4.4",
        "phaser": "4.2.0",
        "phaser4-rex-plugins": "4.0.7",
        "rxjs": "^7.8.2",
        "svelte": "^5.55.9",
        "typesafe-i18n": "^5.27.1",
        "uuid": "^14.0.0",
        "zod": "^3.25.76"
    }
}
